def save_text_as_png(text, filename, dpi=600, font_size=10):
    lines = text.split('\n')
    width = max([len(line) for line in lines]) * 0.12
    height = len(lines) * 0.35
    plt.figure(figsize=(max(width, 6), max(height, 2)))
    plt.axis('off')
    plt.text(0.01, 0.99, text, fontsize=font_size, va='top', family='monospace')
    plt.tight_layout()
    plt.savefig(filename, dpi=dpi, bbox_inches='tight', pad_inches=0.2)
    plt.close()


def analyze_her2(df, label, exclude_study_nos=None):
    """
    Perform HER2 cross-tab meta-analysis for a given sheet (pooled 2x2 table and Fisher's exact).
    """
    print(f"\n========== {label} ==========")

    if exclude_study_nos:
        before_count = len(df)
        df = df[~df['Study_no'].isin(exclude_study_nos)]
        after_count = len(df)
        print(f"Excluded {before_count - after_count} rows based on Study_no filter: {exclude_study_nos}")

    df = df[['Group', 'Study_no', 'HER2-', 'HER2+']].copy()
    df = df[~(((df['HER2-'] == 0) | (df['HER2-'].isna())) &
              ((df['HER2+'] == 0) | (df['HER2+'].isna())))]
    df[['HER2-', 'HER2+']] = df[['HER2-', 'HER2+']].replace(0, 0.1)
    df_clean = df.dropna(subset=['HER2-', 'HER2+'])

    if df_clean['Group'].nunique() < 2:
        print("Not enough group categories for 2x2 odds ratio comparison.")
        return

    grouped = df_clean.groupby('Group')[['HER2+', 'HER2-']].sum()
    groups = grouped.index.tolist()[:2]
    print('grouped check:', groups)

    if len(groups) < 2:
        print("Not enough groups for comparison.")
        return

    table = grouped.loc[groups].values
    oddsratio, pvalue = fisher_exact(table)
    print(f"\n=== 2x2 Table ({groups[0]} vs {groups[1]}) ===")
    print(pd.DataFrame(table, index=groups, columns=['HER2+', 'HER2-']))
    print(f"\nOdds Ratio: {oddsratio:.3f}")
    print(f"P-value: {pvalue:.3f}")

    a = table[0, 0]
    b = table[0, 1]
    c = table[1, 0]
    d = table[1, 1]
    log_or = np.log(oddsratio)
    se_log_or = np.sqrt(1 / a + 1 / b + 1 / c + 1 / d)
    ci_low = np.exp(log_or - 1.96 * se_log_or)
    ci_high = np.exp(log_or + 1.96 * se_log_or)
    print(f"95% CI: ({ci_low:.3f}, {ci_high:.3f})")

    summary_text = f"========== {label} ==========\n\n"
    summary_text += f"=== 2x2 Table ({groups[0]} vs {groups[1]}) ===\n\n"
    summary_text += pd.DataFrame(table, index=groups, columns=['HER2+', 'HER2-']).to_string() + "\n\n"
    summary_text += f"Odds Ratio: {oddsratio:.3f}\n"
    summary_text += f"95% CI: ({ci_low:.3f}, {ci_high:.3f})\n"
    summary_text += f"P-value: {pvalue:.3f}\n"

    output_path = os.path.join(output_dir, f"{label}_summary.png")
    save_text_as_png(summary_text, output_path)


