def compute_lfk_index(effects, variances):
    """Compute the LFK index based on effect sizes and variances."""
    se = np.sqrt(variances)
    z_scores = effects / se
    precision = 1 / se

    order = np.argsort(-precision)
    z_scores = z_scores[order]

    mean_z = np.mean(z_scores)
    deviations = z_scores - mean_z
    cum_dev = np.cumsum(deviations)

    if np.std(deviations, ddof=1) == 0:
        return np.nan

    lfk_index = np.max(np.abs(cum_dev)) / np.std(deviations, ddof=1)
    return lfk_index


